theme = Gruvbox Dark Hard

font-family = Meslo LG S
font-size = 14
font-thicken = true

copy-on-select = clipboard

keybind = cmd+shift+-=new_split:down
keybind = cmd+shift+\=new_split:right

keybind = shift+arrow_left=goto_split:left
keybind = shift+arrow_right=goto_split:right
keybind = shift+arrow_up=goto_split:up
keybind = shift+arrow_down=goto_split:down

keybind = cmd+arrow_right=next_tab
keybind = cmd+arrow_left=previous_tab
